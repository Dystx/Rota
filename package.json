{
  "name": "rota",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --dir apps/web test:e2e",
    "test:visual": "pnpm --dir apps/web test:visual",
    "test:a11y": "pnpm --dir apps/web test:a11y",
    "test:perf": "pnpm --dir apps/web test:perf",
    "qa:motion-gate": "node apps/web/scripts/check-motion-imports.mjs",
    "qa:mapbox-budget": "node apps/web/scripts/check-mapbox-budget.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@axe-core/playwright": "^4.10.2",
    "vitest": "^3.2.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.25.76"
    }
  }
}
