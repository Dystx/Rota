{
  "name": "rota",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:acceptance": "node scripts/build-exact-artifact.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm -r --if-present lint && eslint .",
    "lint:eslint": "eslint .",
    "test": "pnpm test:exact-artifact-unit && pnpm -r --if-present test",
    "test:unit": "pnpm exec vitest run",
    "test:exact-artifact-unit": "node --test scripts/build-exact-artifact.test.mjs scripts/run-exact-artifact-gate.test.mjs",
    "test:rls": "node scripts/run-postgres-policy-tests.mjs",
    "test:e2e": "pnpm --dir apps/web test:e2e",
    "test:visual": "pnpm --dir apps/web test:visual",
    "test:a11y": "pnpm --dir apps/web test:a11y",
    "test:perf": "pnpm --dir apps/web test:perf",
    "qa:motion-gate": "node apps/web/scripts/check-motion-imports.mjs",
    "qa:assets": "node scripts/check-assets.mjs",
    "qa:perf-budget": "node scripts/perf-budget.mjs",
    "check:migrations": "node scripts/check-drizzle-migrations.mjs",
    "repo:safety": "node scripts/check-sensitive-paths.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "test:db-policy": "node scripts/run-postgres-policy-tests.mjs",
    "test:acceptance": "node scripts/run-exact-artifact-gate.mjs --phase final"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  }
}
