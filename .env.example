# Copy to .env.local and fill from either:
# 1) `npx supabase start` output for local development, or
# 2) your hosted Supabase project settings.
#
# Local defaults after `npx supabase start`:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key from CLI output>
# SUPABASE_SERVICE_ROLE_KEY=<secret key from CLI output>
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
