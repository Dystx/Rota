# Copy to .env.local and fill only with the local development values you need.
# Do not commit filled values. Hosted persistence is retired and must not be added here.
# `NEXT_PUBLIC_*` values are bundled for the browser.
# Server-only secrets never belong in client components.
#
# Public/browser-safe config
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_MAPBOX_PUBLIC_TOKEN=
# Nominatim forward-geocoder URL. Optional — the public OpenStreetMap
# instance (`https://nominatim.openstreetmap.org`) is the documented
# fallback. Set to a self-hosted instance for higher rate limits.
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Server-only config
DATABASE_URL=
BETTER_AUTH_SECRET=
# Optional private-canary style URL. Keep empty until the map provider, data,
# attribution, and public-origin decisions are approved. This is server-only;
# the selected style is passed to the browser only when the map is explicitly opened.
RUMIA_MAP_STYLE_URL=

# Playwright E2E auth fixtures
# Required once Better Auth fixtures are enabled.
E2E_TEST_USER_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=

# Product feature flags default to false outside explicitly approved environments.
ENABLE_LIVE_AI=false
ENABLE_STRIPE=false
ENABLE_TRANSACTIONAL_EMAIL=false
ENABLE_TRIP_MESSAGING=false
ENABLE_B2B_BETA=false
ENABLE_GUIDE_BETA=false
ENABLE_OPERATOR_CONSOLE=false
ENABLE_CONSOLE_CONFIG=false
ENABLE_API_DOCS=false
ENABLE_ACTIVITY_MAP=false
ENABLE_ACTIVITY_MAP_STORYTELLING=false
ENABLE_ACTIVITY_MAP_3D=false
ENABLE_PT=false
