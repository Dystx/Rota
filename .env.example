# Copy to .env.local and fill from either:
# 1) `npx supabase start` output for local development, or
# 2) your hosted project dashboard secrets.
#
# Do not commit filled values.
# `NEXT_PUBLIC_*` values are bundled for the browser.
# Server-only secrets never belong in client components.
#
# Public/browser-safe config
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_MAPBOX_PUBLIC_TOKEN=
# Nominatim forward-geocoder URL. Optional — the public OpenStreetMap
# instance (`https://nominatim.openstreetmap.org`) is the documented
# fallback. Set to a self-hosted instance for higher rate limits.
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Server-only config
SUPABASE_SERVICE_ROLE_KEY=

# Playwright E2E auth fixtures (real Supabase sign-in)
# Required to run Playwright; provisions e2e-{admin,reviewer,traveler}@rota.test users.
E2E_TEST_USER_PASSWORD=
# Optional override; defaults to NEXT_PUBLIC_SUPABASE_URL.
# E2E_SUPABASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=

# Product feature flags default to false outside explicitly approved environments.
ENABLE_LIVE_AI=false
ENABLE_STRIPE=false
ENABLE_TRANSACTIONAL_EMAIL=false
ENABLE_TRIP_MESSAGING=false
ENABLE_B2B_BETA=false
ENABLE_GUIDE_BETA=false
ENABLE_OPERATOR_CONSOLE=false
ENABLE_CONSOLE_CONFIG=false
ENABLE_API_DOCS=false
ENABLE_PT=false
