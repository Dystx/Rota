{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"],
      "@repo/ai": ["../../packages/ai/src/index.ts"],
      "@repo/ai/*": ["../../packages/ai/src/*"],
      "@repo/db": ["../../packages/db/src/index.ts"],
      "@repo/db/*": ["../../packages/db/src/*"],
      "@repo/emails": ["../../packages/emails/src/index.ts"],
      "@repo/emails/*": ["../../packages/emails/src/*"],
      "@repo/payments": ["../../packages/payments/src/index.ts"],
      "@repo/payments/*": ["../../packages/payments/src/*"],
      "@repo/config": ["../../packages/config/src/index.ts"],
      "@repo/config/*": ["../../packages/config/src/*"],
      "@repo/routing": ["../../packages/routing/src/index.ts"],
      "@repo/routing/*": ["../../packages/routing/src/*"],
      "@repo/spatial-engine": ["../../packages/spatial-engine/src/index.ts"],
      "@repo/spatial-engine/*": ["../../packages/spatial-engine/src/*"],
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/types/*": ["../../packages/types/src/*"],
      "@repo/ui": ["../../packages/ui/src/index.ts"],
      "@repo/ui/*": ["../../packages/ui/src/*"],
      "@repo/workers": ["../../apps/workers/src/index.ts"],
      "@repo/workers/*": ["../../apps/workers/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "playwright"]
}
