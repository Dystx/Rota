.DS_Store
.turbo
.worktrees/
node_modules
.next
dist
coverage

# Local environment files may contain Supabase service-role/secret keys.
# Keep templates tracked via explicit allow-lists only.
.env
.env.*
!.env.example
!**/.env.example
pnpm-lock.yaml

# Playwright auth storage states (real Supabase JWTs — do not commit)
apps/web/playwright/.auth/

# --- Logs / runtime artifacts ---
*.log
*.pid

# --- sisyphus-agent workflow state (plans, notepads, evidence, boulder.json) ---
.sisyphus/

# --- Repo-root ad-hoc screenshots (regenerated each run) ---
/*.png

# --- Stale root Playwright output dir (active runner writes to apps/web/playwright/test-results/) ---
test-results/

# --- Playwright HTML reporter output (ephemeral; regenerated per run) ---
apps/web/playwright-report/

# --- One-off debug scripts (numbered check-warning*.cjs variants) ---
apps/web/check-*.cjs

# --- Playwright MCP browser-session scratch ---
.playwright-mcp/

# --- Tooling runtime state (oh-my-kimi + Kimi CLI) ---
.omk/
.kimi/
.kimi-code/

# --- Supabase CLI local state (project ref, version probes) ---
supabase/.temp/
